#!/usr/bin/env python3
"""
Tiny test server for verifying the lenticel tunnel works end-to-end.

Usage:
  ./test-server          # listens on port 7979
  ./test-server 8080     # listens on port 8080

Then in another terminal:
  lenticel myproject     # or: lt myproject

And open https://myproject.YOUR_DOMAIN in your browser.
"""
import sys
import datetime
import html
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 7979


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        now = datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S UTC")
        host = self.headers.get("Host", "(none)")
        rows = "".join(
            f"<tr><td>{html.escape(k)}</td><td>{html.escape(v)}</td></tr>"
            for k, v in sorted(self.headers.items())
        )
        body = f"""<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>lenticel test ✓</title>
  <style>
    body {{ font-family: monospace; max-width: 800px; margin: 2em auto; padding: 0 1em; }}
    h1 {{ color: #2a9d2a; }}
    table {{ border-collapse: collapse; width: 100%; }}
    td {{ border: 1px solid #ccc; padding: .3em .6em; vertical-align: top; }}
    td:first-child {{ font-weight: bold; white-space: nowrap; color: #555; width: 1%; }}
    .meta {{ color: #666; margin-bottom: 2em; }}
  </style>
</head>
<body>
  <h1>✓ Tunnel is working</h1>
  <p class="meta">
    <strong>Host:</strong> {html.escape(host)}<br>
    <strong>Path:</strong> {html.escape(self.path)}<br>
    <strong>Time:</strong> {now}<br>
    <strong>Remote:</strong> {self.client_address[0]}
  </p>
  <h2>Request headers</h2>
  <table>{rows}</table>
</body>
</html>
"""
        encoded = body.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(encoded)))
        self.end_headers()
        self.wfile.write(encoded)

    def log_message(self, fmt, *args):
        print(f"  {self.client_address[0]} - {fmt % args}")


if __name__ == "__main__":
    server = HTTPServer(("", PORT), Handler)
    print(f"lenticel test server listening on http://localhost:{PORT}")
    print(f"Run: lenticel myproject")
    print("Press Ctrl-C to stop.")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.")
